{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "Skill(*)",
      "Task(*)",
      "Cron(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__Desktop_Commander__*",
      "mcp__Context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Supabase__*",
      "mcp__claude_ai_Hugging_Face__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-python-hook.sh post-tool-call.py",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-python-hook.sh skill-context.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-python-hook.sh skill-context.py"
          }
        ]
      }
    ]
  }
}
